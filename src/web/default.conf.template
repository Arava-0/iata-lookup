server {
	listen ${WEB_PORT};

	root /usr/share/nginx/html;
	index index.html;

	# SPA fallback
	location / {
		try_files $uri $uri/ /index.html;
	}

	location = /index.html {
		add_header Cache-Control "no-cache, no-store, must-revalidate";
	}

	location /assets/ {
		add_header Cache-Control "public, max-age=31536000, immutable";
	}
}
